{"kind":"Article","sha256":"3bab50c319bce90fbfe7b48703d2055f6f82fe90295021751dd233ad1401f9c3","slug":"index","location":"/index.md","dependencies":[],"frontmatter":{"title":"Welcome to OpenSARLab","content_includes_title":false,"authors":[{"nameParsed":{"literal":"The ASF Services Team","given":"The ASF Services","family":"Team"},"name":"The ASF Services Team","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/ASFOpenSARlab/opensarlab-docs","edit_url":"https://github.com/ASFOpenSARlab/opensarlab-docs/blob/dev/docs/index.md","exports":[{"format":"md","filename":"index.md","url":"/index-ba26abd9b600fcb38e30b44969bc928e.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"What is OpenSARLab?","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"zEzCNa2g0I"}],"identifier":"what-is-opensarlab","label":"What is OpenSARLab?","html_id":"what-is-opensarlab","implicit":true,"key":"PwC2cRXY1n"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"OpenSARLab is a service providing users persistent, cloud-based, customizable computing environments. Groups of scientists and students have access to identical environments, containing the same software, running on the same hardware. It operates in the cloud, which means anyone with a moderately reliable internet connection can access their development environment. OpenSARLab sits alongside ASF’s data archives in AWS, allowing for low latency transfer of large data products.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"SMnLnA35BE"}],"key":"hIc0hB3CdR"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"OpenSARLab is a deployable service that creates an autoscaling Kubernetes cluster in Amazon AWS, running JupyterHub. Users have access to customizable environments running JupyterLab via authenticated accounts with persistent storage.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"EB5248z7MP"}],"key":"KDD6eL0GXf"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"While OpenSARLab was designed with SAR data science in mind, it is not limited to this field. Any group\ndevelopment scenario involving large datasets and/or the need for complicated development environments\ncan benefit from working in an OpenSARLab deployment.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"p8Sf2IXvvX"}],"key":"mH9dD8Lv5A"},{"type":"paragraph","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"link","url":"https://opensarlab.asf.alaska.edu/hub/login","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"Sign in or create an account to try OpenSARLab","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"lMcNj1WcTs"}],"urlSource":"https://opensarlab.asf.alaska.edu/hub/login","key":"ZilIgylaqf"}],"key":"JiinrJsT03"},{"type":"heading","depth":2,"position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"How will OpenSARLab benefit my work as a SAR scientist?","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"ABLznJlxI9"}],"identifier":"how-will-opensarlab-benefit-my-work-as-a-sar-scientist","label":"How will OpenSARLab benefit my work as a SAR scientist?","html_id":"how-will-opensarlab-benefit-my-work-as-a-sar-scientist","implicit":true,"key":"TBD1UcnI3N"},{"type":"paragraph","position":{"start":{"line":16,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"OpenSARLab addresses the fo